# IP开发平台 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============== 必需变量 ==============

# Meshy AI API 密钥 (用于 3D 模型生成)
# 获取地址: https://www.meshy.ai/settings
MESHY_API_KEY=your_meshy_api_key_here

# 应用密钥 (生产环境务必修改为随机字符串)
SECRET_KEY=please_change_this_to_a_random_string_at_least_32_chars

# ============== 数据库配置 ==============

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ipdev_db

# ============== Redis配置 ==============

REDIS_URL=redis://redis:6379/0

# ============== 可选变量 ==============

# 前端 API 地址 (默认 /api)
# VITE_API_BASE_URL=/api

# OSS 配置 (用于存储生成的模型和图片)
# OSS_ACCESS_KEY_ID=your_access_key
# OSS_ACCESS_KEY_SECRET=your_secret
# OSS_BUCKET=ipdev-models
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
